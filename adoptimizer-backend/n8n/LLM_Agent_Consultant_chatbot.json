                      "parameters":  {
                                         "jsCode":  "const campaigns = items.map(i =\u003e i.json);\n\n// Important: lire la question depuis le node Webhook, pas depuis les lignes PostgreSQL.\nconst webhookPayload = $(\u0027Webhook - User Question\u0027).first().json || {};\nconst body = webhookPayload.body || {};\n\nconst question = body.question || webhookPayload.question || \"Analyse des campagnes recentes\";\nconst mode = body.mode || webhookPayload.mode || \"auto\";\n\nif (!question || !String(question).trim()) {\n  throw new Error(\"Question manquante dans le body du webhook\");\n}\n\nreturn [{\n  json: {\n    context: campaigns,\n    question: String(question).trim(),\n    mode: String(mode).toLowerCase()\n  }\n}];"
                                     },
